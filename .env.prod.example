STORAGE_SECRET_KEY=
STORAGE_BUCKET=kuru-bucket
STORAGE_STAGING_BUCKET=kuru-staging
STORAGE_PATH_STYLE=true
KURU_CORS_ALLOWED_ORIGINS=https://kuru-front.pages.dev

# Tunnel Cloudflare (lu par cloudflared ; ignoré par Spring)
TUNNEL_TOKEN=
