# Copier vers .env.prod sur le VPS (ne pas committer).

# API
KURU_SQLITE_FILE=/app/data/kuru.db
STORAGE_ENDPOINT=https://VOTRE_ACCOUNT_ID.r2.cloudflarestorage.com
